            "classification": "adapt",
            "pattern": "small hard plotting rules for vector export, color, size, typography, and parameter blocks"
          }
        ],
        "forbidden_shortcuts": [
          "reuse_current_gallery_graphical_abstract_as_final_template",
          "treat_style_reference_as_data_or_claim_authority",
          "skip_ai_visual_critic_review",
